{{- printf "<?xml version=\"1.0\" encoding=\"utf-8\"?>\n" | safeHTML -}}
{{- printf "<?xml-stylesheet type=\"text/xsl\" href=\"%s\"?>\n" ("/xsl/sitemap.xsl" | absURL) | safeHTML -}}
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
	{{- range where .Site.RegularPages "Section" "pages" }}
		{{- if ne .Sitemap.Disable true }}
	<url>
		<loc>{{ .Permalink }}</loc>
		{{- if not .Lastmod.IsZero }}
		<lastmod>{{ safeHTML (.Lastmod.Format "2006-01-02T15:04:05-03:00") }}</lastmod>
		{{- end }}
		{{- with .Sitemap.ChangeFreq }}
		<changefreq>{{ . }}</changefreq>
		{{- end }}
		{{- if ge .Sitemap.Priority 0.0 }}
		<priority>{{ .Sitemap.Priority }}</priority>
		{{- end }}
	</url>
		{{- end }}
	{{- end }}
</urlset>
